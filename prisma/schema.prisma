// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Guild configuration stored per guild
model GuildConfig {
  id        String   @id @default(cuid())
  guildId   String   @unique
  prefix    String   @default("!")
  modLogChannelId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guild_configs")
}

// Command cooldowns to prevent spam
model CommandCooldown {
  id        String   @id @default(cuid())
  userId    String
  commandName String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([userId, commandName])
  @@map("command_cooldowns")
}

// User data (optional, for infractions/warnings)
model User {
  id          String   @id @default(cuid())
  userId      String   @unique
  infractions Int      @default(0)
  warnings    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}
